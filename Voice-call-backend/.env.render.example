NODE_VERSION=20

ADMIN_USER=admin
ADMIN_PASS=replace_with_a_strong_password

BASE_URL=https://your-render-service.onrender.com
CORS_ORIGIN=https://your-vercel-app.vercel.app

DATABASE_URL=postgresql://postgres.xxxxx:your_password@aws-0-region.pooler.supabase.com:6543/postgres
PGSSLMODE=require

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_VOICE_BUCKET=voice-files

PLIVO_AUTH_ID=your_plivo_auth_id
PLIVO_AUTH_TOKEN=your_plivo_auth_token
PLIVO_SOURCE_NUMBER=your_plivo_number

RETRY_WORKER_INTERVAL_SECONDS=60
