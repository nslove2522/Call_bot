# Environment variables for Voice-call-backend
# Copy this file to .env and fill values before running the server

# Plivo credentials (optional, leave empty to simulate calls)
PLIVO_AUTH_ID=
PLIVO_AUTH_TOKEN=
PLIVO_SOURCE_NUMBER=

# Basic admin credentials used by the UI/API basicAuth
ADMIN_USER=admin
ADMIN_PASS=changeme

# Public base URL for webhooks (must be https for Plivo webhooks)
BASE_URL=https://example.com

# Listening port for the backend
PORT=3001

# SQLite database file location (relative to backend dir or absolute)
# Default: ./data/db.sqlite
DATABASE_FILE=./data/db.sqlite
